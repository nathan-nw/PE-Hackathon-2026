# Copy to `.env` in the repo root — Docker Compose loads it automatically.
# Use these values when you see: "Ports are not available ... 8080 ... bind"
# (another app such as a dev server or Windows "ApplicationWebServer" is using 8080).

LB_HTTP_PORT=18080
LB_STUB_STATUS_PORT=18081

# user-frontend static UI: API base injected as BACKEND_URL (default matches LB on 18080).
USER_FRONTEND_BACKEND_URL=http://localhost:18080
