# Runtime: Next.js reads BACKEND_URL server-side and exposes it via GET /api/config to the browser.
# Docker Compose: set USER_FRONTEND_BACKEND_URL in the repo root `.env` (see root `.env.example`).
# Railway: set on the user-frontend service as BACKEND_URL, or use SYNC_VARIABLES=1 in setup-railway.js.

BACKEND_URL=http://localhost:18080

# Optional: local `npm run dev` without Docker — same as BACKEND_URL
# NEXT_PUBLIC_BACKEND_URL=http://localhost:18080
