# Local dev: copy to `.env` in this folder (`url-shortener/`).
# Docker Compose (repo root): set DATABASE_HOST=db and DATABASE_PORT=5432 via compose — see root `docker-compose.yml`.

FLASK_DEBUG=true
DATABASE_NAME=hackathon_db
# Use 127.0.0.1 for local Docker on Windows (avoids IPv6 localhost vs published port issues).
DATABASE_HOST=127.0.0.1
# Must match the left side of ports in docker-compose.yml (container listens on 5432).
DATABASE_PORT=15432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Connection pool settings
DB_MAX_CONNECTIONS=20
DB_STALE_TIMEOUT=300
DB_TIMEOUT=10
# Seconds (psycopg2); avoids hanging the UI when Postgres is unreachable.
DB_CONNECT_TIMEOUT=5

# Redis (caching + rate limiter shared state)
REDIS_URL=redis://127.0.0.1:6379/0

# Rate limiting — use Redis so limits are shared across containers
RATE_LIMIT_DEFAULT=1000 per minute
RATE_LIMIT_STORAGE=redis://127.0.0.1:6379/1

# Logging
LOG_LEVEL=INFO

# Gunicorn (production)
PORT=5000
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=30
GUNICORN_MAX_REQUESTS=1000
