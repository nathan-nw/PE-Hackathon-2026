# Copy to `.env.railway.setup` in the repo root (gitignored).
# Used by `node setup-railway.js` — see RAILWAY.md.

# Required for setup-railway.js (account or workspace token — not the project token below).
# https://railway.com/account/tokens
RAILWAY_API_TOKEN=

# Optional: push a token onto the **dashboard** service so the Ops tab can call Railway GraphQL.
# Prefer a project token: Railway → your project → Settings → Tokens → create token.
# Or use a second account token here as DASHBOARD_RAILWAY_API_TOKEN=...
DASHBOARD_RAILWAY_PROJECT_TOKEN=

# Optional: pin user-frontend API base when running SYNC_VARIABLES=1 (otherwise uses load-balancer public domain).
# USER_FRONTEND_BACKEND_URL=https://load-balancer-production-8df2.up.railway.app

# Hosted logs → dashboard DB (kafka_logs) without Kafka: shared secret for HTTP POST /api/ingest.
# Omit to auto-generate on first SYNC_VARIABLES=1 (see RAILWAY.md). Or set manually:
# LOG_INGEST_TOKEN=
