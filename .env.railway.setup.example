# Copy to `.env.railway.setup` in the repo root (gitignored).
# Used by `node setup-railway.js` — see RAILWAY.md.

# Required for setup-railway.js (account or workspace token — not the project token below).
# https://railway.com/account/tokens
RAILWAY_API_TOKEN=

# Optional: push a token onto the **dashboard** service so the Ops tab can call Railway GraphQL.
# Prefer a project token: Railway → your project → Settings → Tokens → create token.
# Or use a second account token here as DASHBOARD_RAILWAY_API_TOKEN=...
DASHBOARD_RAILWAY_PROJECT_TOKEN=

# Optional: pin user-frontend API base when running SYNC_VARIABLES=1 (otherwise uses load-balancer public domain).
# USER_FRONTEND_BACKEND_URL=https://load-balancer-production-8df2.up.railway.app

# Optional: override dashboard-backend k6 target (defaults to https://<load-balancer RAILWAY_PUBLIC_DOMAIN> during SYNC_VARIABLES=1).
# LOAD_TEST_TARGET_URL=https://your-lb.up.railway.app
# Optional: must match load-balancer LOAD_TEST_BYPASS_TOKEN so k6 can bypass edge rate limits (compose default works if unset).
# LOAD_TEST_BYPASS_TOKEN=pe-hackathon-k6-edge-bypass

# Hosted logs → dashboard DB (kafka_logs) without Kafka: shared secret for HTTP POST /api/ingest.
# Omit to auto-generate on first SYNC_VARIABLES=1 (see RAILWAY.md). Or set manually:
# LOG_INGEST_TOKEN=
# Optional: use http://<private>:PORT/api/ingest instead of https://<public>/api/ingest
# LOG_INGEST_USE_PRIVATE_URL=1

# Optional: Ops tab Railway watchdog poll interval (seconds); SYNC_VARIABLES=1 sets RAILWAY_WATCHDOG_POLL_SEC on dashboard.
# RAILWAY_WATCHDOG_POLL_SEC=15

# Chaos tab (hosted): SYNC_VARIABLES=1 sets these on the **dashboard** service by default.
# CHAOS_KILL_ENABLED=1   — required for Kill/Reboot buttons in production (default when unset during sync).
# CHAOS_KILL_ENABLED=0   — set in this file to disable chaos after sync.
# RAILWAY_WATCHDOG_AUTO_RECOVER=1 — watchdog redeploys on CRASHED/FAILED only, not after Chaos Kill (default 1).
# CHAOS_ALLOWED_SERVICES=url-shortener-a,load-balancer  — optional override if Railway service names differ from the default allowlist.

# Optional: set CHAOS_RAILWAY_LOG=0 on the **dashboard** service to silence `[dashboard][railway-chaos]` server logs (default: logs on).
# CHAOS_RAILWAY_LOG=0
